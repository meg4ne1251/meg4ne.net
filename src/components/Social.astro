---
// Icon-only social links, requested for the About profile card
// ("github, x, mail のアイコン … 文字は入れなくていい").
interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const socials = [
  { label: 'GitHub', href: 'https://github.com', icon: 'github' },
  { label: 'X', href: 'https://x.com', icon: 'x' },
  { label: 'Email', href: 'mailto:me@meg4ne.net', icon: 'mail' },
] as const;
---

<div class:list={['social-row', className]}>
  {
    socials.map((s) => (
      <a class="social" href={s.href} aria-label={s.label} rel="me noopener" target={s.icon === 'mail' ? undefined : '_blank'}>
        {s.icon === 'github' && (
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            />
          </svg>
        )}
        {s.icon === 'x' && (
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.59-7.933Zm-1.29 19.52h2.039L6.486 3.24H4.298L17.61 20.674Z"
            />
          </svg>
        )}
        {s.icon === 'mail' && (
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="m3.5 7 8.5 6 8.5-6" />
          </svg>
        )}
      </a>
    ))
  }
</div>

<style>
  .social-row {
    display: flex;
    gap: 8px;
  }
  .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--bd);
    border-radius: 4px;
    color: var(--t2);
    transition: all 0.2s;
  }
  .social:hover {
    color: var(--cy);
    border-color: var(--cy);
    background: rgba(0, 204, 245, 0.05);
  }
  .social svg {
    width: 17px;
    height: 17px;
    display: block;
  }
</style>
