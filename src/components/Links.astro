---
import Label from './Label.astro';
import Heading from './Heading.astro';
import { LINKS } from '../data/site';
---

<section id="links" class="links">
  <div class="inner">
    <Label text="contact.ts" />
    <Heading>Connect</Heading>
    <div class="list">
      {
        LINKS.map((lk) => (
          <a
            class="link-card"
            href={lk.href}
            target={lk.href.startsWith('mailto:') ? undefined : '_blank'}
            rel={lk.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
          >
            <div class="dot" />
            <div>
              <div class="link-label">{lk.label}</div>
              <div class="link-sub">{lk.sub}</div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .links {
    padding: clamp(64px, 8vw, 100px) clamp(24px, 5vw, 80px);
    border-top: 1px solid var(--bd);
  }
  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .list {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .link-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 22px;
    border: 1px solid rgba(0, 204, 245, 0.14);
    border-radius: 4px;
    background: var(--bg2);
    text-decoration: none;
    transition: all 0.2s;
    min-width: 175px;
  }
  .link-card:hover {
    border-color: var(--cy);
    background: rgba(0, 204, 245, 0.05);
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--cy);
    flex-shrink: 0;
  }
  .link-label {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--t1);
  }
  .link-sub {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--t3);
    margin-top: 2px;
  }

  @media (max-width: 768px) {
    .list {
      flex-direction: column;
    }
    .link-card {
      width: 100%;
    }
  }
</style>
