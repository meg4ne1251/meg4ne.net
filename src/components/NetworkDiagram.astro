---
// Static SVG network topology for the homelab.
// (Some node colours are intentionally hard-coded hex values, matching the design.)
---

<div class="diagram">
  <p class="diagram-title">Network Topology — meg4ne.net Homelab</p>
  <svg viewBox="0 0 720 370" class="diagram-svg" role="img" aria-label="meg4ne.net homelab network topology">
    <!-- Internet -->
    <text x="340" y="20" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)">Internet</text>
    <line x1="360" y1="24" x2="360" y2="50" stroke="rgba(255,255,255,.09)" stroke-width="1"></line>

    <!-- Router -->
    <g>
      <rect x="280" y="50" width="160" height="44" rx="2" fill="#0e1520" stroke="rgba(255,255,255,.07)" stroke-width="1"
      ></rect>
      <text x="360" y="69" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="14" fill="#c8d8e8"
        >RTX830</text
      >
      <text x="360" y="85" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)"
        >Router (Yamaha)</text
      >
    </g>
    <line x1="360" y1="94" x2="360" y2="124" stroke="rgba(255,255,255,.09)" stroke-width="1"></line>

    <!-- L2 Switch -->
    <g>
      <rect
        x="240"
        y="124"
        width="240"
        height="44"
        rx="2"
        fill="#0e1520"
        stroke="rgba(255,255,255,.07)"
        stroke-width="1"></rect>
      <text x="360" y="143" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="14" fill="#c8d8e8"
        >x510L-28GTX</text
      >
      <text x="360" y="159" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)"
        >Switch (Allied Telesis)</text
      >
    </g>
    <line x1="360" y1="168" x2="360" y2="196" stroke="rgba(255,255,255,.09)" stroke-width="1"></line>

    <!-- Branch line to 4 devices -->
    <line x1="115" y1="196" x2="615" y2="196" stroke="rgba(255,255,255,.09)" stroke-width="1"></line>
    <line x1="115" y1="196" x2="115" y2="216" stroke="rgba(255,255,255,.09)" stroke-width="1"></line>
    <line x1="305" y1="196" x2="305" y2="216" stroke="rgba(255,255,255,.09)" stroke-width="1"></line>
    <line x1="460" y1="196" x2="460" y2="216" stroke="rgba(255,255,255,.09)" stroke-width="1"></line>
    <line x1="615" y1="196" x2="615" y2="216" stroke="rgba(255,255,255,.09)" stroke-width="1"></line>

    <!-- Main Server (accent) -->
    <g>
      <rect
        x="5"
        y="216"
        width="220"
        height="46"
        rx="2"
        fill="rgba(0,204,245,.05)"
        stroke="rgba(0,204,245,.38)"
        stroke-width="1"></rect>
      <text x="115" y="236" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="14" fill="#00ccf5"
        >HPE ML350 Gen9</text
      >
      <text x="115" y="252" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)"
        >Main Server (HPE ProLiant)</text
      >
    </g>

    <!-- Backup NAS -->
    <g>
      <rect
        x="230"
        y="216"
        width="150"
        height="46"
        rx="2"
        fill="#0e1520"
        stroke="rgba(255,255,255,.07)"
        stroke-width="1"></rect>
      <text x="305" y="236" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="14" fill="#c8d8e8"
        >Backup NAS</text
      >
      <text x="305" y="252" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)"
        >Storage / Backup</text
      >
    </g>

    <!-- Desktop PC -->
    <g>
      <rect
        x="385"
        y="216"
        width="150"
        height="46"
        rx="2"
        fill="#0e1520"
        stroke="rgba(255,255,255,.07)"
        stroke-width="1"></rect>
      <text x="460" y="236" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="14" fill="#c8d8e8"
        >Desktop PC</text
      >
      <text x="460" y="252" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)"
        >Workstation</text
      >
    </g>

    <!-- Cisco AP -->
    <g>
      <rect
        x="540"
        y="216"
        width="150"
        height="46"
        rx="2"
        fill="#0e1520"
        stroke="rgba(255,255,255,.07)"
        stroke-width="1"></rect>
      <text x="615" y="236" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="14" fill="#c8d8e8"
        >Cisco AP</text
      >
      <text x="615" y="252" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)"
        >Wireless AP</text
      >
    </g>

    <!-- AP -> MacBook (wireless) -->
    <line x1="615" y1="262" x2="615" y2="290" stroke="rgba(0,204,245,.3)" stroke-width="1" stroke-dasharray="4 3"
    ></line>

    <!-- MacBook -->
    <g>
      <rect
        x="540"
        y="290"
        width="150"
        height="46"
        rx="2"
        fill="#0e1520"
        stroke="rgba(255,255,255,.07)"
        stroke-width="1"></rect>
      <text x="615" y="310" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="14" fill="#c8d8e8"
        >MacBook</text
      >
      <text x="615" y="326" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)"
        >Wi-Fi client</text
      >
    </g>

    <!-- Legend -->
    <g transform="translate(0,358)">
      <line x1="0" y1="0" x2="20" y2="0" stroke="rgba(255,255,255,.09)" stroke-width="1"></line>
      <text x="28" y="4" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)">Wired (LAN)</text>
      <line x1="160" y1="0" x2="180" y2="0" stroke="rgba(0,204,245,.3)" stroke-width="1" stroke-dasharray="4 3"></line>
      <text x="188" y="4" font-family="JetBrains Mono,monospace" font-size="12" fill="var(--t2)">Wireless (Wi-Fi)</text>
    </g>
  </svg>
</div>

<style>
  .diagram {
    border: 1px solid var(--bd);
    border-radius: 4px;
    background: #080c14;
    padding: 20px 24px;
    overflow-x: auto;
  }
  .diagram-title {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--t2);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .diagram-svg {
    width: 100%;
    max-width: 720px;
    display: block;
    min-width: 520px;
  }
</style>
