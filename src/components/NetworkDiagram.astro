---
// Static SVG network topology for the homelab, transcribed from the prototype.
// (Some node colours are intentionally hard-coded hex values, matching the design.)
---

<div class="diagram">
  <p class="diagram-title">Network Topology — meg4ne.net Homelab</p>
  <svg viewBox="0 0 720 330" class="diagram-svg" role="img" aria-label="meg4ne.net homelab network topology">
    <!-- Row 1: Internet → Cloudflare → Router → Switch → PCs -->
    <text x="20" y="56" font-family="JetBrains Mono,monospace" font-size="9" fill="#28384a">Internet</text>
    <line x1="20" y1="60" x2="20" y2="72" stroke="rgba(0,204,245,.2)" stroke-width="1"></line>

    <!-- Cloudflare (accent) -->
    <g>
      <rect x="0" y="72" width="120" height="38" rx="2" fill="rgba(0,204,245,.05)" stroke="rgba(0,204,245,.38)" stroke-width="1"></rect>
      <text x="60" y="87" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#00ccf5">Cloudflare</text>
      <text x="60" y="101" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#28384a">CDN / DNS</text>
    </g>
    <line x1="120" y1="91" x2="156" y2="91" stroke="rgba(0,204,245,.24)" stroke-width="1"></line>
    <polygon points="155,87 163,91 155,95" fill="rgba(0,204,245,.22)"></polygon>

    <!-- ONU / Router -->
    <g>
      <rect x="163" y="72" width="120" height="38" rx="2" fill="#0e1520" stroke="rgba(255,255,255,.07)" stroke-width="1"></rect>
      <text x="223" y="87" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#c8d8e8">ONU / Router</text>
      <text x="223" y="101" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#28384a">WAN Edge</text>
    </g>
    <line x1="283" y1="91" x2="319" y2="91" stroke="rgba(255,255,255,.09)" stroke-width="1" stroke-dasharray="4 3"></line>
    <polygon points="318,87 326,91 318,95" fill="rgba(255,255,255,.08)"></polygon>

    <!-- L2 Switch -->
    <g>
      <rect x="326" y="72" width="120" height="38" rx="2" fill="#0e1520" stroke="rgba(255,255,255,.07)" stroke-width="1"></rect>
      <text x="386" y="87" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#c8d8e8">L2 Switch</text>
      <text x="386" y="101" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#28384a">8-port GbE</text>
    </g>
    <line x1="446" y1="91" x2="482" y2="91" stroke="rgba(255,255,255,.09)" stroke-width="1" stroke-dasharray="4 3"></line>
    <polygon points="481,87 489,91 481,95" fill="rgba(255,255,255,.08)"></polygon>

    <!-- Desktop PC -->
    <g>
      <rect x="489" y="72" width="110" height="38" rx="2" fill="#0e1520" stroke="rgba(255,255,255,.07)" stroke-width="1"></rect>
      <text x="544" y="87" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#c8d8e8">Desktop PC</text>
      <text x="544" y="101" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#28384a">Ryzen 9 · Win11</text>
    </g>

    <!-- Laptop (top right) -->
    <g>
      <rect x="608" y="72" width="100" height="38" rx="2" fill="#0e1520" stroke="rgba(255,255,255,.07)" stroke-width="1"></rect>
      <text x="658" y="87" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#c8d8e8">Laptop</text>
      <text x="658" y="101" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#28384a">i7 · Ubuntu</text>
    </g>

    <!-- Switch → Proxmox -->
    <line x1="386" y1="110" x2="386" y2="158" stroke="rgba(255,255,255,.09)" stroke-width="1" stroke-dasharray="4 3"></line>
    <polygon points="382,157 386,165 390,157" fill="rgba(255,255,255,.08)"></polygon>

    <!-- Proxmox Host (accent) -->
    <g>
      <rect x="316" y="165" width="140" height="44" rx="2" fill="rgba(0,204,245,.05)" stroke="rgba(0,204,245,.38)" stroke-width="1"></rect>
      <text x="386" y="183" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#00ccf5">Proxmox Host</text>
      <text x="386" y="197" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#28384a">i5-12400 · 32GB RAM</text>
    </g>

    <!-- Proxmox → VMs -->
    <line x1="386" y1="209" x2="386" y2="238" stroke="rgba(255,255,255,.09)" stroke-width="1" stroke-dasharray="4 3"></line>
    <line x1="270" y1="238" x2="510" y2="238" stroke="rgba(255,255,255,.07)" stroke-width="1" stroke-dasharray="4 3"></line>
    <line x1="270" y1="238" x2="270" y2="252" stroke="rgba(255,255,255,.07)" stroke-width="1" stroke-dasharray="4 3"></line>
    <line x1="330" y1="238" x2="330" y2="252" stroke="rgba(255,255,255,.07)" stroke-width="1" stroke-dasharray="4 3"></line>
    <line x1="390" y1="238" x2="390" y2="252" stroke="rgba(255,255,255,.07)" stroke-width="1" stroke-dasharray="4 3"></line>
    <line x1="450" y1="238" x2="450" y2="252" stroke="rgba(255,255,255,.07)" stroke-width="1" stroke-dasharray="4 3"></line>
    <line x1="510" y1="238" x2="510" y2="252" stroke="rgba(255,255,255,.07)" stroke-width="1" stroke-dasharray="4 3"></line>

    <!-- VM chips -->
    <g>
      <rect x="241" y="252" width="58" height="22" rx="1" fill="#07090f" stroke="rgba(255,255,255,.06)" stroke-width="1"></rect>
      <text x="270" y="266" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#56697c">GitLab</text>
    </g>
    <g>
      <rect x="301" y="252" width="58" height="22" rx="1" fill="#07090f" stroke="rgba(255,255,255,.06)" stroke-width="1"></rect>
      <text x="330" y="266" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#56697c">Docker</text>
    </g>
    <g>
      <rect x="361" y="252" width="58" height="22" rx="1" fill="#07090f" stroke="rgba(255,255,255,.06)" stroke-width="1"></rect>
      <text x="390" y="266" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#56697c">Grafana</text>
    </g>
    <g>
      <rect x="421" y="252" width="58" height="22" rx="1" fill="#07090f" stroke="rgba(255,255,255,.06)" stroke-width="1"></rect>
      <text x="450" y="266" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#56697c">Zabbix</text>
    </g>
    <g>
      <rect x="481" y="252" width="58" height="22" rx="1" fill="#07090f" stroke="rgba(255,255,255,.06)" stroke-width="1"></rect>
      <text x="510" y="266" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#56697c">Laptop</text>
    </g>

    <!-- Legend -->
    <g transform="translate(0,300)">
      <circle cx="4" cy="5" r="4" fill="rgba(0,204,245,.3)"></circle>
      <text x="14" y="9" font-family="JetBrains Mono,monospace" font-size="9" fill="#28384a">Public / Cloudflare</text>
      <line x1="140" y1="5" x2="160" y2="5" stroke="rgba(255,255,255,.09)" stroke-width="1" stroke-dasharray="4 3"></line>
      <text x="166" y="9" font-family="JetBrains Mono,monospace" font-size="9" fill="#28384a">Internal LAN</text>
    </g>
  </svg>
</div>

<style>
  .diagram {
    border: 1px solid var(--bd);
    border-radius: 4px;
    background: #080c14;
    padding: 20px 24px;
    overflow-x: auto;
  }
  .diagram-title {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--t3);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .diagram-svg {
    width: 100%;
    max-width: 720px;
    display: block;
    min-width: 520px;
  }
</style>
