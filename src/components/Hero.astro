---
// Hero section — typing animation powered by vanilla JS (no React needed).

interface Span {
  c: string;
  t: string;
}

const CODE_LINES: Span[][] = [
  [
    { c: '#4a9ef0', t: 'const ' },
    { c: 'var(--cy)', t: 'me' },
    { c: 'var(--t1)', t: ' = {' },
  ],
  [
    { c: 'var(--t2)', t: '  uni:    ' },
    { c: '#a5f3a0', t: '"電気通信大学"' },
    { c: 'var(--t2)', t: ',' },
  ],
  [
    { c: 'var(--t2)', t: '  circles:' },
    { c: '#a5f3a0', t: '"VLL, MMA"' },
    { c: 'var(--t2)', t: ',' },
  ],
  [
    { c: 'var(--t2)', t: '  hobby:  ' },
    { c: '#a5f3a0', t: '"server / 3D"' },
    { c: 'var(--t2)', t: ',' },
  ],
  [
    { c: 'var(--t2)', t: '  stack: [' },
    { c: '#a5f3a0', t: '"Proxmox"' },
    { c: 'var(--t2)', t: ', ...],' },
  ],
  [{ c: 'var(--t1)', t: '}' }],
];

const CODE_DOTS = ['#ff5f57', '#febc2e', '#28c840'];
const BADGES = ['VLL', 'MMA'];
---

<section class="hero">
  <div class="dot-grid"></div>
  <div class="ambient"></div>
  <div class="inner fade-in">
    <!-- Text -->
    <div>
      <p class="prompt">
        <span class="prompt-dim">root@meg4ne:~# </span>
        <span class="prompt-cmd">whoami</span>
      </p>
      <h1 class="hero-name">
        <span id="hero-typed">megane</span><span id="hero-cursor" class="cursor" aria-hidden="true">_</span>
      </h1>
      <div class="tags">
        <p class="subtitle">UEC · 3D modeler · Homelab</p>
        <div class="badges">
          {BADGES.map((c) => <span class="badge">{c}</span>)}
        </div>
      </div>
    </div>
    <!-- Code card -->
    <div class="hero-code-card">
      <div class="code-dots">
        {CODE_DOTS.map((c) => <div class="code-dot" style={`background:${c}`} />)}
      </div>
      {
        CODE_LINES.map((line) => (
          <div class="code-line">
            {line.map((s) => (
              <span style={`color:${s.c}`}>{s.t}</span>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const cursor = document.getElementById('hero-cursor');

  if (cursor) {
    window.setTimeout(() => {
      cursor.dataset.done = '';
    }, 420);
  }
</script>

<style>
  .hero {
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px clamp(24px, 7vw, 100px);
    position: relative;
    overflow: hidden;
  }

  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.032) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .ambient {
    position: absolute;
    left: -8%;
    top: 10%;
    width: 800px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 204, 245, 0.05) 0%, transparent 62%);
    pointer-events: none;
  }

  .inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: center;
    max-width: 1400px;
  }

  .prompt {
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--t2);
    margin-bottom: 20px;
  }

  .prompt-dim {
    color: var(--t3);
  }

  .prompt-cmd {
    color: var(--cy);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(72px, 11vw, 152px);
    font-weight: 700;
    line-height: 0.85;
    letter-spacing: -0.055em;
    background: linear-gradient(145deg, var(--t1) 0%, var(--cy) 72%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 28px;
  }

  .cursor {
    -webkit-text-fill-color: var(--cy);
    animation: blink 0.9s step-end infinite;
  }

  .cursor[data-done] {
    animation: none;
    opacity: 0;
  }

  .tags {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .subtitle {
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--t2);
  }

  .badges {
    display: flex;
    gap: 6px;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--cy);
    border: 1px solid rgba(0, 204, 245, 0.28);
    padding: 3px 9px;
    border-radius: 2px;
    background: rgba(0, 204, 245, 0.04);
  }

  .hero-code-card {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.9;
    padding: 22px 26px;
    border: 1px solid rgba(0, 204, 245, 0.18);
    border-radius: 4px;
    background: rgba(12, 16, 24, 0.9);
    box-shadow: 0 0 48px rgba(0, 204, 245, 0.07);
    min-width: 300px;
    white-space: pre;
  }

  .code-dots {
    display: flex;
    gap: 6px;
    margin-bottom: 14px;
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.6;
  }

  .code-line {
    display: flex;
    flex-wrap: wrap;
  }

  /* Media queries — previously in global.css with !important */
  @media (max-width: 800px) {
    .hero-code-card {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .hero-name {
      font-size: clamp(60px, 17vw, 104px);
      letter-spacing: -0.04em;
    }
  }

  @media (max-width: 400px) {
    .hero-name {
      font-size: 56px;
    }
  }
</style>
