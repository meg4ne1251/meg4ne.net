---
import { PLATFORM_COLORS, type PostWithPlatform } from '../data/site';

interface Props {
  post: PostWithPlatform;
  uid: string;
}
const { post, uid } = Astro.props;
const color = PLATFORM_COLORS[post.platform];
const patternId = `stripe-${uid}`;
---

<a class="card" href={post.href} target="_blank" rel="noopener noreferrer">
    <svg class="thumb-bg" aria-hidden="true">
      <defs>
        <pattern id={patternId} x="0" y="0" width="12" height="12" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <rect width="6" height="12" fill="rgba(255,255,255,.022)"></rect>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill={`url(#${patternId})`}></rect>
      <rect width="100%" height="100%" fill={`${color}08`}></rect>
    </svg>
    <div class="thumb-fg">
      <div class="thumb-dot" style={`background:${color}`}></div>
      <span class="thumb-text">article image</span>
    </div>
  </div>
  <div class="body">
    <div class="platform">
      <span class="platform-dot" style={`background:${color}`}></span>
      <span class="platform-name">{post.platform}</span>
    </div>
    <p class="title">{post.t}</p>
    <div class="meta">
      <span class="date">{post.d}</span>
      {post.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
</a>

<style>
  .card {
    border: 1px solid var(--bd);
    border-radius: 4px;
    overflow: hidden;
    background: var(--bg2);
    cursor: pointer;
    transition: border-color 0.15s;
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }
  .card:hover {
    border-color: rgba(255, 255, 255, 0.14);
  }
  .thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--bg3);
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }
  .thumb-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .thumb-fg {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 7px;
  }
  .thumb-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    opacity: 0.45;
  }
  .thumb-text {
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--t3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .body {
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .platform {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .platform-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .platform-name {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t2);
  }
  .title {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--t1);
    line-height: 1.6;
    flex: 1;
  }
  .meta {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    align-items: center;
    padding-top: 4px;
  }
  .date {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t2);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1px 6px;
    border-radius: 2px;
    opacity: 0.65;
  }
</style>
