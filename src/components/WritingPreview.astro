---
import Label from './Label.astro';
import ArticleCard from './ArticleCard.astro';
import { FEATURED_POSTS } from '../data/site';
---

<section id="blog" class="writing">
  <div class="inner">
    <Label text="blog/rss.ts" />
    <div class="header">
      <h2 class="title">Posts</h2>
      <a class="all-link" href="/blog">ls ~/blog/</a>
    </div>
    <div class="grid">
      {FEATURED_POSTS.map((post, i) => <ArticleCard post={post} uid={`hp-${i}`} />)}
    </div>
    <p class="note">// RSS/API で最新記事を自動取得する予定</p>
  </div>
</section>

<style>
  .writing {
    padding: clamp(64px, 8vw, 100px) clamp(24px, 5vw, 80px);
    border-top: 1px solid var(--bd);
  }
  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 40px;
  }
  .title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 60px);
    font-weight: 600;
    letter-spacing: -0.032em;
    color: var(--t1);
    margin: 0;
  }
  .all-link {
    background: transparent;
    border: 1px solid var(--bd);
    color: var(--t2);
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 8px 18px;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.2s;
    white-space: nowrap;
    text-decoration: none;
  }
  .all-link:hover {
    background: rgba(0, 204, 245, 0.06);
    border-color: var(--cy);
    color: var(--cy);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }
  .note {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t3);
    margin-top: 14px;
  }
</style>
