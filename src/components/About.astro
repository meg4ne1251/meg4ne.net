---
import Label from './Label.astro';
import Heading from './Heading.astro';
import Social from './Social.astro';
import { PROFILE, CIRCLES, TECH, TECH_GROUP_COLORS } from '../data/site';
---

<section id="about" class="about">
  <div class="inner">
    <Label text="about_me.ts" />
    <Heading>Who I Am</Heading>
    <div class="grid">
      <!-- Profile -->
      <div class="card">
        <p class="card-label">profile</p>
        {
          PROFILE.map(([k, val]) => (
            <div class="row">
              <span class="row-key">{k}</span>
              <span class="row-val">{val}</span>
            </div>
          ))
        }
        <div class="row">
          <span class="row-key">サークル</span>
          <span class="row-val">
            {CIRCLES.map((c, i) => (
              <>
                {i > 0 && ', '}
                <a href={c.href} target="_blank" rel="noopener noreferrer" class="row-link">
                  {c.label}
                </a>
              </>
            ))}
          </span>
        </div>
        <Social class="profile-social" />
      </div>
      <!-- Tech stack -->
      <div class="card card-wide">
        <p class="card-label">stack</p>
        <div class="groups">
          {
            TECH.map((grp) => (
              <div>
                <p class="group-label">{grp.g}</p>
                <div class="chips">
                  {grp.items.map((item) => (
                    <span class="chip" style={`color:${TECH_GROUP_COLORS[grp.g] ?? 'var(--t2)'}`}>
                      {item}
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: clamp(64px, 8vw, 112px) clamp(24px, 5vw, 80px);
    border-top: 1px solid var(--bd);
  }
  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 14px;
  }
  .card {
    padding: 26px;
    border: 1px solid var(--bd);
    border-radius: 4px;
    background: var(--bg2);
  }
  .card-wide {
    grid-column: span 2;
  }
  .card-label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--cy);
    margin-bottom: 18px;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }
  .row {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: 12px;
    padding-bottom: 12px;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--bd);
  }
  .row-key {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--t2);
    padding-top: 2px;
  }
  .row-val {
    font-family: var(--font-sans);
    font-size: 17px;
    color: var(--t1);
    line-height: 1.5;
  }
  .profile-social {
    padding-top: 2px;
  }
  .row-link {
    color: var(--cy);
    text-decoration: none;
  }
  .row-link:hover {
    text-decoration: underline;
  }
  .groups {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .group-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--t3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 13px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 5px 11px;
    border-radius: 2px;
    line-height: 1.4;
  }
</style>
